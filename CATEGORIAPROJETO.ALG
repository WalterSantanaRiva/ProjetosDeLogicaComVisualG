Algoritmo "CategoriaProjeto"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Classifica projeto pelo número de linhas.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Linhas de codigo: ")
   leia(num1)

   se num1 < 1000 entao
      escreval("Pequeno porte")
   senao
      se num1 <= 5000 entao
         escreval("Medio porte")
      senao
         escreval("Grande porte")
      fimse
   fimse
   Fimalgoritmo