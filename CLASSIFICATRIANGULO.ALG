Algoritmo "ClassificaTriangulo"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Verifica se é possível formar um triângulo e classifica seu
//tipo.
// Autor(a)    : Walter
// Data atual  : 13/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1, num2, num3: real
   mens: caractere

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o lado A: ")
   leia(num1)

   escreva("Digite o lado B: ")
   leia(num2)

   escreva("Digite o lado C: ")
   leia(num3)

   se (num1 < num2 + num3) e (num2 < num1 + num3) e (num3 < num1 + num2) entao
      se (num1 = num2) e (num2 = num3) entao
         mens <- "Triangulo Equilatero"
      senao
         se (num1 = num2) ou (num2 = num3) ou (num1 = num3) entao
            mens <- "Triangulo Isosceles"
         senao
            mens <- "Triangulo Escaleno"
         fimse
      fimse
   senao
      mens <- "Nao e possivel formar um triangulo"
   fimse
   escreval(mens)
   Fimalgoritmo