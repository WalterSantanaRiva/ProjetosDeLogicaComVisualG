Algoritmo "ConsumoMedio"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo   : Le a distância percorrida por um carro e o total de combustível gasto. Calcula o consumo médio.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
  num1: Real
  num2: Real
  resultado: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva ("digite a distância percorrida pelo carro: ")
leia(num1)
escreva ("digite o total de combustível gasto: ")
leia(num2)
resultado<- num1/num2
escreval ("o valor do consumo médio é: ", resultado, "Km/L")


Fimalgoritmo