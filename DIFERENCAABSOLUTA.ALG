Algoritmo "DiferencaAbsoluta"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Calcula a diferença positiva entre dois números.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1, num2, resultado: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
    escreva("Digite o valor A: ")
   leia(num1)

   escreva("Digite o valor B: ")
   leia(num2)

   se num1 > num2 entao
      resultado <- num1 - num2
   senao
      resultado <- num2 - num1
   fimse

   escreval("Resultado: ", resultado)
   Fimalgoritmo