Algoritmo "L01H"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Calcula volume de caixa retangular.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1, num2, num3, volume: real
   
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o comprimento: ")
   leia(num1)

   escreva("Digite a largura: ")
   leia(num2)

   escreva("Digite a altura: ")
   leia(num3)

   volume <- num1 * num2 * num3

   escreval("Volume: ", volume)
   Fimalgoritmo