Algoritmo "MultaTransito"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Classifica multa pela velocidade excedida.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1, num2, limite: real
   
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Velocidade da via: ")
   leia(num1)

   escreva("Velocidade do veiculo: ")
   leia(num2)

   limite <- num1

   se num2 <= limite entao
      escreval("Sem multa")
   senao
      se num2 <= limite * 1.20 entao
         escreval("Multa Media")
      senao
         se num2 <= limite * 1.50 entao
            escreval("Multa Grave")
         senao
            escreval("Multa Gravissima")
         fimse
      fimse
   fimse
   Fimalgoritmo