Algoritmo "OrdemDecrescente"
// Disciplina   : [Lógica de Programaçăo com VIsualG]
// Professor   : Jailson
// Descriçăo    : Exibe tręs números em ordem decrescente.
// Autor(a)    : Walter Santana Riva
// Data atual  : 30/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1, num2, num3: real
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite o primeiro valor: ")
   leia(num1)
   escreva("Digite o segundo valor: ")
   leia(num2)
   escreva("Digite o terceiro valor: ")
   leia(num3)
   
   se num1 > num2 e num1 > num3 entao
      se num2 > num3 entao
         escreval(num1, " ", num2, " ", num3)
      senao
         escreval(num1, " ", num3, " ", num2)
      fimse
   senao
      se num2 > num3 entao
         se num1 > num3 entao
            escreval(num2, " ", num1, " ", num3)
         senao
            escreval(num2, " ", num3, " ", num1)
         fimse
      senao
         se num1 > num2 entao
            escreval(num3, " ", num1, " ", num2)
         senao
            escreval(num3, " ", num2, " ", num1)
         fimse
      fimse
   fimse

Fimalgoritmo
