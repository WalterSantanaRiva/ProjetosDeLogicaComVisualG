Algoritmo "PesoIdeal2"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo    : Calcula o peso ideal com base na altura e sexo.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1: inteiro
   num2, peso: real
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o sexo (1-feminino 2-masculino): ")
   leia(num1)

   escreva("Digite a altura: ")
   leia(num2)

   se num1 = 2 entao
      peso <- (72.7 * num2) - 58
   senao
      peso <- (62.1 * num2) - 44.7
   fimse

   escreval("Peso ideal: ", peso)
Fimalgoritmo
