Algoritmo "PodeVotar"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo    : Verificar se uma pessoa pode votar com base no ano de
//nascimento.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   atual, nascimento, idade: inteiro
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o ano atual: ")
   leia(atual)

   escreva("Digite o ano de nascimento: ")
   leia(nascimento)

   idade <- atual - nascimento

   se idade >= 16 entao
      escreval("Pode votar")
   senao
      escreval("Nao pode votar")
   fimse
Fimalgoritmo