Algoritmo "PostoCombustivel"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo    : Calcula o valor a pagar com base no tipo de combustível e
//litros.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   litros, preco, total: real
   tipu: caractere
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o tipo (A/G): ")
   leia(tipu)

   escreva("Digite os litros: ")
   leia(litros)

   se tipu = "A" entao
      preco <- 2.90
      se litros <= 20 entao
         total <- litros * preco * 0.97
      senao
         total <- litros * preco * 0.95
      fimse
   senao
      preco <- 3.30
      se litros <= 20 entao
         total <- litros * preco * 0.96
      senao
         total <- litros * preco * 0.94
      fimse
   fimse

   escreval("Total: R$ ", total)
Fimalgoritmo