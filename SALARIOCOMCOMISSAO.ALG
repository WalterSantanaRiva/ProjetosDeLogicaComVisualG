Algoritmo "SalarioComComissao"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo    : Calcula o salário total de um vendedor com base nas vendas e
//comissăo.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   salarioFixo, vendas, total: real
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o salario fixo: ")
   leia(salarioFixo)

   escreva("Digite o total de vendas: ")
   leia(vendas)

   se vendas <= 1500 entao
      total <- salarioFixo + (vendas * 0.03)
   senao
      total <- salarioFixo + (1500 * 0.03) + ((vendas - 1500) * 0.05)
   fimse

   escreval("Salario total: ", total)

Fimalgoritmo