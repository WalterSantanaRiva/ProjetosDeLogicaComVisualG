Algoritmo "SalarioVendedor"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo    : Escreve um algoritmo que leia o número de carros vendidos,
//o valor total das vendas, o salário fixo e a comissăo por carro. Calcule e
//escreva o salário final.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   carros, valorVendas, salarioFixo, comissao, salarioFinal: real


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite numero de carros vendidos: ")
   leia(carros)

   escreva("Digite valor total das vendas: ")
   leia(valorVendas)

   escreva("Digite salario fixo: ")
   leia(salarioFixo)

   escreva("Digite comissao por carro: ")
   leia(comissao)

   salarioFinal <- salarioFixo + (carros * comissao) + (valorVendas * 0.05)

   escreva("Salario final: ", salarioFinal)


Fimalgoritmo