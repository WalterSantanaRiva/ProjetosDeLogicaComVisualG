Algoritmo "SinalNumero"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Verifica se o número é positivo, negativo ou zero.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite um numero: ")
   leia(num1)

   se num1 > 0 entao
      escreval("Positivo")
   senao
      se num1 < 0 entao
         escreval("Negativo")
      senao
         escreval("Zero")
      fimse
   fimse
   Fimalgoritmo