Algoritmo "SistemaLogin"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo    : Verifica código e senha para liberar acesso.
// Autor(a)    : Walter Santa
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   codigo, senha: inteiro
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o codigo: ")
   leia(codigo)

   se codigo <> 1234 entao
      escreval("Usuario invalido!")
   senao
      escreva("Digite a senha: ")
      leia(senha)

      se senha = 9999 entao
         escreval("Acesso permitido")
      senao
         escreval("Senha incorreta")
      fimse
   fimse
Fimalgoritmo