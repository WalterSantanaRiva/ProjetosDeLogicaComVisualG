Algoritmo "StatusCluster"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Classifica a carga de processamento.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Carga (%): ")
   leia(num1)

   se num1 <= 40 entao
      escreval("Ocioso")
   senao
      se num1 <= 70 entao
         escreval("Estavel")
      senao
         se num1 <= 90 entao
            escreval("Atencao")
         senao
            escreval("Critico - escalar novo no")
         fimse
      fimse
   fimse
   Fimalgoritmo