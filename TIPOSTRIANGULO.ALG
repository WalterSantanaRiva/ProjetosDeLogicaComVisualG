Algoritmo "TiposTriangulo"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo    : Identifica o tipo de triângulo pelos lados.
// Autor(a)    : Walter
// Data atual  : 14/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   num1, num2, num3: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite lado 1: ")
   leia(num1)

   escreva("Digite lado 2: ")
   leia(num2)

   escreva("Digite lado 3: ")
   leia(num3)

   se num1 = num2 e num2 = num3 entao
      escreval("Equilatero")
   senao
      se num1 = num2 ou num1 = num3 ou num2 = num3 entao
         escreval("Isosceles")
      senao
         escreval("Escaleno")
      fimse
   fimse
   Fimalgoritmo