Algoritmo "TrocaValores"
// Disciplina   : [Lógica de Programaçăo usando VisualG]
// Professor   : Jailson
// Descriçăo   : Le dois valores armazenados nas variáveis A e B. Troca os valores entre elas.
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
  num1: inteiro
  num2: inteiro
  guarda: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva (" escreva o primeiro valor A: ")
leia(num1)
escreva (" escreva o segundo valor B: ")
leia(num2)
guarda<- num1
num1<- num2
num2<- guarda
escreval ("o valor A trocado é: ", num1, " o valor B trocado é: ", num2)


Fimalgoritmo